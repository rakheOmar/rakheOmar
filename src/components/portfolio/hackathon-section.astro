---
import { HackathonCard } from "@/components/hackathon-card";
import portfolioData from "@/data/portfolio.json";

const { hackathons } = portfolioData;
---

<section id="hackathons">
  <h2 class="mb-2 font-serif text-lg">Hackathons</h2>

  <ul class="ml-4 divide-y divide-dashed border-l">
    {hackathons.map((project) => (
      <li>
        <HackathonCard
          client:load
          dates={project.dates}
          description={project.description}
          image={project.image}
          links={project.links}
          location={project.location}
          title={project.title}
        />
      </li>
    ))}
  </ul>
</section>
