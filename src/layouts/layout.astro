---
import "@/styles/global.css";

import Seo from "@/components/seo.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Omar Rakhe | Full-Stack Developer & AI Engineer",
  description = "Building scalable web apps and exploring Agentic AI. View my projects, resume, and hackathon journey.",
} = Astro.props;
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <Seo title={title} description={description} />

    <meta
      name="keywords"
      content="Omar Rakhe, Full Stack Developer, AI Engineer, Data Science, React Developer, Mumbai, Portfolio, Markdrop, Artificial Intelligence, Web Development"
    >
    <meta name="robots" content="index, follow">
    <meta name="theme-color" content="#09090b">
    <meta name="generator" content={Astro.generator}>

    <!-- Preconnect to external resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://api.github.com" crossorigin>
    <link
      rel="dns-prefetch"
      href="https://github-contributions-api.jogruber.de"
    >

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  </head>
  <body>
    <div class="relative min-h-screen w-full overflow-hidden bg-background">
      <div class="-z-10 absolute inset-0 h-full w-full bg-background"></div>

      <div class="relative z-10">
        <slot />
      </div>
    </div>
  </body>
</html>
